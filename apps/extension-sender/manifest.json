{
  "manifest_version": 3,
  "name": "EasyTransfer Sender",
  "version": "0.1.0",
  "description": "Offline high-speed frame sender for EasyTransfer",
  "permissions": ["storage"],
  "action": {
    "default_title": "EasyTransfer Sender",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
